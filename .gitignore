@'
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*

# next.js
/.next/
/out/
/build

# misc
.DS_Store
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files — keep the example, ignore real secrets
.env
.env.local
.env*.local
!.env.example

# typescript
*.tsbuildinfo
next-env.d.ts

# runtime data + generated media (never commit)
/data
/public/audio
/public/cache
/public/videos
/public/uploads
'@ | Set-Content -Encoding utf8 .gitignore/public/music
