# ─── Reelify environment ──────────────────────────────────────────────
# Copy this file to .env.local and fill in your keys. Never commit .env.local.
# LLM keys are NOT here — users bring their own (BYOK) from the browser.

# ── Required for voice, captions, and media ──
# Murf Falcon (text-to-speech). One-time character allowance — protect it.
MURF_API_KEY=your_murf_api_key_here
# Optional: override the Murf websocket host (leave blank for defaults).
# MURF_WS_HOST=

# Deepgram (word-level caption timing). Falls back to estimated timing if missing.
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Pexels (stock photos + b-roll video).
PEXELS_API_KEY=your_pexels_api_key_here

# Jamendo (royalty-free music). Optional — local /public/music is the fallback.
JAMENDO_CLIENT_ID=your_jamendo_client_id_here

# ── Credit protection ──
# Max Murf characters the app will ever spend (one-time allowance ~100k).
# Leave headroom under your real cap. Default if unset: 95000.
MURF_CHAR_BUDGET=95000

# ── Optional: per-device rate limits (in-memory) ──
# RL_STUDIO_MAX=8
# RL_STUDIO_WINDOW_MS=300000
# RL_RENDER_MAX=15
# RL_RENDER_WINDOW_MS=300000
# RL_EDIT_MAX=30
# RL_EDIT_WINDOW_MS=300000